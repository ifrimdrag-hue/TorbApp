# ═══════════════════════════════════════════════════════════════════════════════
# Variabilele marcate cu [SECRET] nu se stochează în acest fișier pe producție.
# Se configurează în GitHub Actions → Settings → Secrets and variables → Actions
# și sunt injectate automat la deploy ca variabile de mediu.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Autentificare Flask ────────────────────────────────────────────────────────
# [SECRET] Generare: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# ── Modul AI / Asistent AI ─────────────────────────────────────────────────────
# [SECRET] Generare: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=

# Model AI implicit (optional — default: claude-opus-4-7)
AI_MODEL=claude-opus-4-7

# ── Logging & server ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
SESSION_COOKIE_SECURE=1
# PORT=5000

# ── Date PRD→DEV (buton admin /admin/db) ───────────────────────────────────────
# Căile absolute către baza de date prod și dev pe VPS. Butonul „Date PRD→DEV"
# copiază mereu PROD_DB_PATH peste DEV_DB_PATH (producția nu e niciodată scrisă).
# Setați ambele pe AMBELE servicii cu aceleași valori. Default (dacă lipsesc):
# baza de date locală a instanței — copiere pe loc, fără efect între medii.
# Necesită drept de citire pe data/ prod și scriere pe data/ dev (grup comun).
# PROD_DB_PATH=/var/www/html/torb-py/data/torb.db
# DEV_DB_PATH=/var/www/html/torb-py-dev/data/torb.db

# ── SMTP pentru resetare parolă (opțional) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=Torb Logistic <office@tobra.ro>
# [SECRET]
SMTP_USER=
# [SECRET]
SMTP_PASSWORD=

# ══ eMAG Marketplace ══════════════════════════════════════════════════════════

# [SECRET] Autentificare HTTP Basic Auth
EMAG_USERNAME=
EMAG_PASSWORD=

# ID depozit eMAG — vizibil în câmpul stock[].warehouse_id din orice ofertă live
EMAG_WAREHOUSE_ID=1

# Stoc de siguranță: cantitățile ≤ această valoare sunt trimise ca 0 (default: 5)
EMAG_STOCK_SAFETY_THRESHOLD=5

# URL API eMAG (optional)
# EMAG_API_URL=https://marketplace-api.emag.ro/api-3

# ══ Shopify ═══════════════════════════════════════════════════════════════════

SHOPIFY_SHOP_DOMAIN=basilur-tea-romania.myshopify.com
SHOPIFY_LOCATION_ID=110603567429
SHOPIFY_STOCK_SAFETY_THRESHOLD=5

# [SECRET] OAuth client credentials — Shopify Dev Dashboard → Apps → SyncStoc
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# ── OpenClaw Integration ──────────────────────────────────────────────────────
# Flask nu se conectează direct la gateway. Rulează CLI-ul `openclaw agent`
# ca utilizatorul `openclaw` printr-un wrapper, via sudo (vezi
# docs/TECHNICAL.md pentru scriptul wrapper + regula sudoers).
# Opțional — calea wrapper-ului (default: /usr/local/bin/torb-openclaw-ask)
# OPENCLAW_ASK_BIN=/usr/local/bin/torb-openclaw-ask
# Opțional — timeout în secunde pentru un răspuns (default: 120)
# OPENCLAW_TIMEOUT=120
