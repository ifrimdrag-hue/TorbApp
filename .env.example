# ── Autentificare Flask ────────────────────────────────────────────────────────
# Generare: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-generate-with-secrets-token-hex-32

# ── Modul AI / Asistent AI ─────────────────────────────────────────────────────
# Generare: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-...

# Model AI implicit (optional — default: claude-opus-4-7)
# Alte opțiuni: claude-sonnet-4-6, claude-haiku-4-5-20251001
AI_MODEL=claude-opus-4-7

# ── Logging ────────────────────────────────────────────────────────────────────
# Nivele: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# ── Cookie security ────────────────────────────────────────────────────────────
# Setează 1 pe VPS cu HTTPS/nginx. Lasă 0 pentru dev local (HTTP).
SESSION_COOKIE_SECURE=0

# ── SMTP pentru resetare parolă (opțional) ─────────────────────────────────────
# Dacă nu este configurat, resetarea prin email este dezactivată.
# Opțiune 1 — Gmail cu App Password:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587
#   SMTP_USER=adresa@gmail.com  SMTP_PASSWORD=app_password_16_chars
# Opțiune 2 — Postfix local (relay Gmail):
#   SMTP_HOST=localhost  SMTP_PORT=25  (fără SMTP_USER/SMTP_PASSWORD)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Torb Logistic <noreply@torb.ro>

# ── Credențiale eMAG Marketplace (HTTP Basic Auth) ───────────────────────────
# Username-ul contului de vânzător eMAG (adresa de email)
EMAG_USERNAME=email@firma.ro

# Parola contului eMAG Marketplace (nu API Key — eMAG folosește HTTP Basic Auth)
EMAG_PASSWORD=parola_emag

# URL API eMAG (optional — default: https://marketplace-api.emag.ro/api-3)
# EMAG_API_URL=https://marketplace-api.emag.ro/api-3

# ID depozit eMAG (optional — detectat automat dacă ai un singur depozit)
# EMAG_WAREHOUSE_ID=

# Număr minim de zile stoc de siguranță pentru alertele eMAG (default: 7)
# EMAG_STOCK_SAFETY_THRESHOLD=7

# ── Credențiale Shopify (basilurtea.ro) ───────────────────────────────────────
# Domeniu intern Shopify (NU basilurtea.ro — cel din admin Shopify)
# NOTĂ: config.py citește SHOPIFY_SHOP_DOMAIN (nu SHOPIFY_SHOP)
SHOPIFY_SHOP_DOMAIN=basilurtea.myshopify.com

# Access Token: Shopify Admin → Settings → Apps and sales channels
# → Develop apps → Create app → API credentials → Admin API access token
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Versiunea API Shopify (optional — default: 2024-01)
# SHOPIFY_API_VERSION=2024-01

# ID-ul locației de stoc din Shopify (numeric).
# Dacă ai o singură locație, lasă gol — scriptul îl detectează automat.
# Dacă ai mai multe: Admin → Settings → Locations → click pe locație → URL conține ID-ul
SHOPIFY_LOCATION_ID=

# ── Server (doar pentru lansare directă cu python app/app.py) ─────────────────
# FLASK_DEBUG=0
# PORT=5000
